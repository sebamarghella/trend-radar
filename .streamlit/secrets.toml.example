# Copy this file to .streamlit/secrets.toml and fill in your credentials.
# Streamlit auto-loads it on startup; the app reads st.secrets.telegram.*.
#
# 1. Talk to @BotFather on Telegram → /newbot → save the bot token.
# 2. Send any message to your new bot, then visit
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates to grab your chat_id.
#    Or message @userinfobot for the chat id directly.
#
# Streamlit Cloud users: paste the same TOML into "App settings → Secrets"
# instead of committing this file.

[telegram]
bot_token = "REPLACE_WITH_YOUR_BOTFATHER_TOKEN"
chat_id = "REPLACE_WITH_YOUR_NUMERIC_CHAT_ID"
