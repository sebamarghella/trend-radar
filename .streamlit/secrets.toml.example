# Copy this file to .streamlit/secrets.toml and fill in your credentials.
# Streamlit auto-loads it on startup. On Streamlit Cloud, paste the same TOML
# into "App settings -> Secrets" instead of committing this file.

# --- Telegram alerts ---
# 1. Talk to @BotFather on Telegram -> /newbot -> save the bot token.
# 2. Message @userinfobot to get your numeric chat id.
[telegram]
bot_token = "REPLACE_WITH_YOUR_BOTFATHER_TOKEN"
chat_id = "REPLACE_WITH_YOUR_NUMERIC_CHAT_ID"

# --- GitHub (enables the "Commit presets" button) ---
# Fine-grained PAT with "Contents: Read and write" on this repo only:
#   github.com/settings/tokens?type=beta -> Generate -> Repository access:
#   trend-radar -> Repository permissions -> Contents: Read and write.
# Lets the app push strategies/*.json + strategy_assignments.json so presets
# persist across Cloud restarts and are used by the alert cron.
[github]
token = "REPLACE_WITH_FINE_GRAINED_PAT"
repo = "sebamarghella/trend-radar"
branch = "main"
